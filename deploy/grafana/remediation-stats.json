{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "title": "Remediation Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.9 }] } }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "title": "Overall Success Rate",
      "type": "gauge",
      "targets": [{ "expr": "sum(rate(chatcli_operator_remediations_total{result=\"success\"}[24h])) / sum(rate(chatcli_operator_remediations_total[24h]))", "legendFormat": "Success Rate" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Remediations (24h)",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(chatcli_operator_remediations_total[24h]))", "legendFormat": "Total" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 120 }, { "color": "red", "value": 300 }] } } },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Median Remediation Duration",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.50, rate(chatcli_operator_remediation_duration_seconds_bucket[24h]))", "legendFormat": "p50" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Auto-Approved (24h)",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(chatcli_operator_approvals_total{result=\"auto_approved\"}[24h])) or vector(0)", "legendFormat": "Auto" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "title": "Success Rate by Action Type",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*success.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*failed.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "title": "Remediations by Action Type & Result",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (action_type, result) (increase(chatcli_operator_remediations_total[5m]))", "legendFormat": "{{action_type}} ({{result}})" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "title": "Success Rate per Action Type (24h)",
      "type": "barchart",
      "options": { "orientation": "horizontal", "showValue": "always" },
      "targets": [{ "expr": "sum by (action_type) (increase(chatcli_operator_remediations_total{result=\"success\"}[24h])) / sum by (action_type) (increase(chatcli_operator_remediations_total[24h]))", "legendFormat": "{{action_type}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "title": "Remediation Duration Distribution",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(chatcli_operator_remediation_duration_seconds_bucket[30m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, rate(chatcli_operator_remediation_duration_seconds_bucket[30m]))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, rate(chatcli_operator_remediation_duration_seconds_bucket[30m]))", "legendFormat": "p99" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "title": "Operator Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "title": "Operator Reconciliation Rate",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (result) (rate(chatcli_operator_reconciliations_total[5m]))", "legendFormat": "{{result}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "title": "Reconciliation Duration",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(chatcli_operator_reconciliation_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.99, rate(chatcli_operator_reconciliation_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 1 } } },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 33 },
      "title": "Instance Health",
      "type": "timeseries",
      "targets": [{ "expr": "chatcli_operator_instance_ready", "legendFormat": "{{name}} ({{namespace}})" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["chatcli", "aiops", "remediation", "operator"],
  "time": { "from": "now-24h", "to": "now" },
  "title": "ChatCLI AIOps - Remediation Stats & Operator Health",
  "uid": "chatcli-remediation-stats"
}
