{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "title": "Remediation Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "title": "Overall Success Rate",
      "type": "gauge",
      "targets": [
        {
          "expr": "sum(rate(chatcli_operator_remediations_total{result=\"success\"}[24h])) / sum(rate(chatcli_operator_remediations_total[24h]))",
          "legendFormat": "Success Rate"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Remediations (24h)",
      "type": "stat",
      "targets": [
        { "expr": "sum(increase(chatcli_operator_remediations_total[24h]))", "legendFormat": "Total" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Median Remediation Duration",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(chatcli_operator_remediation_duration_seconds_bucket[24h]))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Auto-Approved (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(chatcli_operator_approvals_total{result=\"auto_approved\"}[24h])) or vector(0)",
          "legendFormat": "Auto"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "title": "Success Rate by Action Type",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*success.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*failed.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "title": "Remediations by Action Type & Result",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (action_type, result) (increase(chatcli_operator_remediations_total[5m]))",
          "legendFormat": "{{action_type}} ({{result}})"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "title": "Success Rate per Action Type (24h)",
      "type": "barchart",
      "options": { "orientation": "horizontal", "showValue": "always" },
      "targets": [
        {
          "expr": "sum by (action_type) (increase(chatcli_operator_remediations_total{result=\"success\"}[24h])) / sum by (action_type) (increase(chatcli_operator_remediations_total[24h]))",
          "legendFormat": "{{action_type}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "title": "Remediation Duration Distribution",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(chatcli_operator_remediation_duration_seconds_bucket[30m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, rate(chatcli_operator_remediation_duration_seconds_bucket[30m]))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, rate(chatcli_operator_remediation_duration_seconds_bucket[30m]))", "legendFormat": "p99" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "title": "Operator Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "title": "Operator Reconciliation Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (result) (rate(chatcli_operator_reconciliations_total[5m]))", "legendFormat": "{{result}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "title": "Reconciliation Duration",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(chatcli_operator_reconciliation_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.99, rate(chatcli_operator_reconciliation_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 1 } } },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 33 },
      "title": "Instance Health",
      "type": "timeseries",
      "targets": [
        { "expr": "chatcli_operator_instance_ready", "legendFormat": "{{name}} ({{namespace}})" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "title": "Approval Workflow Analytics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 40 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Pending Approvals",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(chatcli_operator_approvals_pending) or vector(0)",
          "legendFormat": "Pending"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 40 },
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "single" }
      },
      "title": "Approval Decision Distribution",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (result) (increase(chatcli_operator_approvals_total[24h]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 40 },
      "title": "Approval Duration by Mode",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (mode, le) (rate(chatcli_operator_approval_duration_seconds_bucket[30m])))",
          "legendFormat": "{{mode}} p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (mode, le) (rate(chatcli_operator_approval_duration_seconds_bucket[30m])))",
          "legendFormat": "{{mode}} p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (mode, le) (rate(chatcli_operator_approval_duration_seconds_bucket[30m])))",
          "legendFormat": "{{mode}} p99"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 40 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "title": "Auto-Approve Rate",
      "type": "gauge",
      "targets": [
        {
          "expr": "sum(increase(chatcli_operator_approvals_total{result=\"auto_approved\"}[24h])) / sum(increase(chatcli_operator_approvals_total[24h]))",
          "legendFormat": "Auto-Approve Rate"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "title": "SLA Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 49 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "title": "SLA Compliance by Severity",
      "type": "gauge",
      "targets": [
        {
          "expr": "chatcli_operator_sla_compliance_percentage",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 49 },
      "options": { "orientation": "horizontal", "showValue": "always" },
      "title": "Response Time by Severity p95",
      "type": "barchart",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (severity, le) (rate(chatcli_operator_sla_response_time_seconds_bucket[24h])))",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 49 },
      "options": { "orientation": "horizontal", "showValue": "always" },
      "title": "Resolution Time by Severity p95",
      "type": "barchart",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (severity, le) (rate(chatcli_operator_sla_resolution_time_seconds_bucket[24h])))",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*critical.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*warning.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 49 },
      "title": "SLA Violations Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (severity, type) (rate(chatcli_operator_sla_violations_total[5m]))",
          "legendFormat": "{{severity}} - {{type}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "title": "Session & Platform",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 58 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Sessions",
      "type": "stat",
      "targets": [
        {
          "expr": "chatcli_session_active_total",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 58 },
      "title": "Session Operations",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (operation) (rate(chatcli_session_operations_total[5m]))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 58 },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Server Info",
      "type": "stat",
      "targets": [
        {
          "expr": "chatcli_server_info",
          "legendFormat": "v{{version}} | {{provider}} / {{model}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "light-blue", "value": null },
              { "color": "green", "value": 86400 },
              { "color": "super-light-green", "value": 604800 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 58 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Server Uptime",
      "type": "stat",
      "targets": [
        {
          "expr": "chatcli_server_uptime_seconds",
          "legendFormat": "Uptime"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["chatcli", "aiops", "remediation", "operator"],
  "time": { "from": "now-24h", "to": "now" },
  "title": "ChatCLI AIOps - Remediation Stats & Operator Health",
  "uid": "chatcli-remediation-stats"
}
