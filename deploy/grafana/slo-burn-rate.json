{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "title": "Error Budget Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.25 }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.75 }] } }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "Error Budget Remaining",
      "type": "gauge",
      "targets": [{ "expr": "chatcli_operator_slo_error_budget_remaining", "legendFormat": "{{slo_name}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0 }] } }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Current SLI Value",
      "type": "stat",
      "targets": [{ "expr": "chatcli_operator_slo_current_value", "legendFormat": "{{service}} - {{slo_name}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "orange", "value": 6 }, { "color": "red", "value": 14 }] } } },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Burn Rate (1h)",
      "type": "stat",
      "targets": [{ "expr": "chatcli_operator_slo_burn_rate{window=\"1h\"}", "legendFormat": "{{service}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "SLO Violations (24h)",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(chatcli_operator_slo_violations_total[24h]))", "legendFormat": "Violations" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "title": "Multi-Window Burn Rates",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 14.4 }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "14.4x threshold" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash" } }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "title": "Burn Rate - 1h Window (Page threshold: 14.4x)",
      "type": "timeseries",
      "targets": [
        { "expr": "chatcli_operator_slo_burn_rate{window=\"1h\"}", "legendFormat": "{{service}} (1h)" },
        { "expr": "vector(14.4)", "legendFormat": "14.4x threshold" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 6 }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "6x threshold" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash" } }, { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "title": "Burn Rate - 6h Window (Ticket threshold: 6x)",
      "type": "timeseries",
      "targets": [
        { "expr": "chatcli_operator_slo_burn_rate{window=\"6h\"}", "legendFormat": "{{service}} (6h)" },
        { "expr": "vector(6)", "legendFormat": "6x threshold" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "title": "Burn Rate - 24h Window",
      "type": "timeseries",
      "targets": [
        { "expr": "chatcli_operator_slo_burn_rate{window=\"24h\"}", "legendFormat": "{{service}} (24h)" },
        { "expr": "vector(3)", "legendFormat": "3x threshold" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "title": "Burn Rate - 72h Window",
      "type": "timeseries",
      "targets": [
        { "expr": "chatcli_operator_slo_burn_rate{window=\"72h\"}", "legendFormat": "{{service}} (72h)" },
        { "expr": "vector(1)", "legendFormat": "1x threshold" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "title": "SLA Compliance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 99 }] } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 25 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "title": "SLA Compliance %",
      "type": "gauge",
      "targets": [{ "expr": "chatcli_operator_sla_compliance_percentage", "legendFormat": "{{severity}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 25 },
      "title": "SLA Response Time by Severity",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(chatcli_operator_sla_response_time_seconds_bucket[30m]))", "legendFormat": "p95 {{severity}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 25 },
      "title": "SLA Violations Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (severity, type) (increase(chatcli_operator_sla_violations_total[1h]))", "legendFormat": "{{severity}}/{{type}}" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["chatcli", "aiops", "slo", "sla"],
  "time": { "from": "now-24h", "to": "now" },
  "title": "ChatCLI AIOps - SLO Burn Rate & SLA Compliance",
  "uid": "chatcli-slo-burn-rate"
}
